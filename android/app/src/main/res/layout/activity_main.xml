<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textColor="#e94560"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_subtitle"
            android:textSize="14sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_mode"
            android:textColor="#cccccc"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <RadioGroup
            android:id="@+id/rg_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <RadioButton
                android:id="@+id/rb_mode_api"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/mode_api"
                android:textColor="#ffffff"
                android:buttonTint="#e94560"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rb_mode_local"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/mode_local"
                android:textColor="#ffffff"
                android:buttonTint="#e94560" />
        </RadioGroup>

        <!-- API Mode fields -->
        <LinearLayout
            android:id="@+id/ll_api_fields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_api_url"
                android:textColor="#cccccc"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_api_url"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="textUri"
                android:textColor="#ffffff"
                android:textColorHint="#555555"
                android:hint="@string/hint_api_url"
                android:background="#1e1e3a"
                android:padding="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_api_key"
                android:textColor="#cccccc"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_api_key"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="textPassword"
                android:textColor="#ffffff"
                android:textColorHint="#555555"
                android:hint="@string/hint_api_key"
                android:background="#1e1e3a"
                android:padding="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_model"
                android:textColor="#cccccc"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_model"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="text"
                android:textColor="#ffffff"
                android:textColorHint="#555555"
                android:hint="@string/hint_model"
                android:background="#1e1e3a"
                android:padding="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

        </LinearLayout>

        <!-- Local Mode fields -->
        <LinearLayout
            android:id="@+id/ll_local_fields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_local_server_url"
                android:textColor="#cccccc"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_local_server_url"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="textUri"
                android:textColor="#ffffff"
                android:textColorHint="#555555"
                android:hint="@string/hint_local_server_url"
                android:background="#1e1e3a"
                android:padding="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/usage_guide_local"
                android:textColor="#aaaaaa"
                android:textSize="12sp"
                android:background="#0d0d1a"
                android:padding="12dp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="12dp" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_goal"
            android:textColor="#cccccc"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_goal"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:inputType="textMultiLine"
            android:textColor="#ffffff"
            android:textColorHint="#555555"
            android:hint="@string/hint_goal"
            android:background="#1e1e3a"
            android:padding="12dp"
            android:gravity="top"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_overlay"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/btn_overlay"
                android:textSize="12sp"
                android:textColor="#ffffff"
                android:background="#2d2d5e"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_accessibility"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/btn_accessibility"
                android:textSize="12sp"
                android:textColor="#ffffff"
                android:background="#2d2d5e"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_start"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_start"
            android:textSize="16sp"
            android:textColor="#ffffff"
            android:background="#e94560"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/status_idle"
            android:textColor="#4CAF50"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_usage"
            android:textColor="#888888"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/usage_guide"
            android:textColor="#aaaaaa"
            android:textSize="12sp"
            android:background="#0d0d1a"
            android:padding="12dp"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>
</ScrollView>
